{
  "expo": {
    "name": "Wholesale Pharmacy",
    "slug": "pharma-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pharma-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F9D58"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.uttam2132.pharmaapp"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e5c27e2d-bb30-4229-b564-f06b2cb0562d"
      }
    },
    "owner": "uttam2132"
  }
}
